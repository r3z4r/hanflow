{
	"name": "hanflow",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"packageManager": "pnpm@10.30.3",
	"scripts": {
		"dev": "vite dev",
		"dev:full": "pnpm services:up && vite dev",
		"services:up": "(docker compose up -d postgres redis 2>/dev/null || docker-compose up -d postgres redis)",
		"services:down": "(docker compose down 2>/dev/null || docker-compose down)",
		"build": "vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"lint": "prettier --check . && eslint .",
		"format": "prettier --write .",
		"db:generate": "drizzle-kit generate",
		"db:migrate": "drizzle-kit migrate",
		"db:studio": "drizzle-kit studio"
	},
	"devDependencies": {
		"@eslint/js": "^10.0.1",
		"@sveltejs/adapter-node": "^5.5.4",
		"@sveltejs/kit": "^2.57.0",
		"@sveltejs/vite-plugin-svelte": "^7.0.0",
		"@types/node": "^24",
		"@types/pg": "^8.20.0",
		"drizzle-kit": "^0.31.10",
		"eslint": "^10.4.0",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.17.0",
		"globals": "^17.4.0",
		"prettier": "^3.8.1",
		"prettier-plugin-svelte": "^3.5.1",
		"svelte": "^5.55.2",
		"svelte-check": "^4.4.6",
		"typescript": "^6.0.2",
		"typescript-eslint": "^8.58.1",
		"vite": "^8.0.7"
	},
	"dependencies": {
		"@ai-sdk/anthropic": "^3.0.81",
		"@ai-sdk/google": "^3.0.80",
		"@auth/core": "^0.34.3",
		"@auth/drizzle-adapter": "^1.11.2",
		"@auth/sveltekit": "^1.11.2",
		"@xyflow/svelte": "^1.6.0",
		"ai": "^6.0.197",
		"drizzle-orm": "^0.45.2",
		"ioredis": "^5.11.1",
		"pg": "^8.21.0",
		"zod": "^4.4.3"
	}
}
